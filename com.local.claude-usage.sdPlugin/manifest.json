{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.local.claude-usage",
  "Name": "Claude Usage",
  "Version": "1.0.0.0",
  "Author": "Community",
  "Description": "Shows your Claude session (5h) and weekly (7d) usage limits on Stream Deck keys — the same data Claude Code's /usage command displays.",
  "Category": "Claude Usage",
  "CategoryIcon": "imgs/category-icon",
  "Icon": "imgs/plugin-icon",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "CodePath": "bin/plugin.js",
  "Actions": [
    {
      "Name": "Claude Usage",
      "UUID": "com.local.claude-usage.meter",
      "Icon": "imgs/actions/meter/icon",
      "Tooltip": "Show a Claude usage meter (Session 5h / Weekly 7d / Opus / Sonnet).",
      "PropertyInspectorPath": "ui/inspector.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/meter/key",
          "TitleAlignment": "bottom"
        }
      ]
    }
  ]
}