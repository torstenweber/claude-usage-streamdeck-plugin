{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.local.claude-usage",
  "Name": "Claude Usage",
  "Version": "1.1.0.0",
  "Author": "Community",
  "Description": "Shows Claude usage on Stream Deck keys: live session (5h) & weekly (7d) limits from /usage, plus tokens and cost parsed from local Claude Code logs. Windows + macOS.",
  "Category": "Claude Usage",
  "CategoryIcon": "imgs/category-icon",
  "Icon": "imgs/plugin-icon",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.5"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    },
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "CodePath": "bin/plugin.js",
  "Actions": [
    {
      "Name": "Claude Usage",
      "UUID": "com.local.claude-usage.meter",
      "Icon": "imgs/actions/meter/icon",
      "Tooltip": "Show a Claude usage meter: Session/Weekly limits, or tokens/cost (today or session).",
      "PropertyInspectorPath": "ui/inspector.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/meter/key",
          "TitleAlignment": "bottom"
        }
      ]
    }
  ]
}