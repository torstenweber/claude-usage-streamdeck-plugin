{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.saeedkolivand.claude-usage",
  "Name": "AI Coding Usage Meter",
  "Version": "1.4.0.0",
  "Author": "Saeed Kolivand",
  "Description": "Shows AI coding usage on Stream Deck keys: live session (5h) & weekly (7d) limits, plus tokens and cost parsed from local logs. Works with Claude Code. Windows + macOS.",
  "URL": "https://github.com/saeedkolivand/claude-usage-streamdeck-plugin",
  "Category": "AI Coding Usage Meter",
  "CategoryIcon": "imgs/category-icon",
  "Icon": "imgs/plugin-icon",
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "6.9"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    },
    {
      "Platform": "mac",
      "MinimumVersion": "12"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "CodePath": "bin/plugin.js",
  "Actions": [
    {
      "Name": "Usage Meter",
      "UUID": "com.saeedkolivand.claude-usage.meter",
      "Icon": "imgs/actions/meter/icon",
      "Tooltip": "Show a Claude usage meter: Session/Weekly limits, or tokens/cost (today or session).",
      "PropertyInspectorPath": "ui/inspector.html",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/meter/key",
          "TitleAlignment": "bottom"
        }
      ]
    }
  ]
}